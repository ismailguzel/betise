  "include_indices": true,
  "base_series": "ar",
  "features": {
    "linear_trend": {
      "enabled": true,
      "direction": "upward"
    },
    "quadratic_trend": {
      "enabled": false,
      "direction": "upward",
      "location": "center"
    },
    "cubic_trend": {
      "enabled": false,
      "direction": "upward",
      "location": "center"
    },
    "exponential_trend": {
      "enabled": false,
      "direction": "upward"
    },
    "arch": {
      "enabled": false
    },
    "garch": {
      "enabled": false
    },
    "egarch": {
      "enabled": false
    },
    "aparch": {
      "enabled": false
    },
    "single_seasonality": {
      "enabled": false
    },
    "multiple_seasonality": {
      "enabled": false,

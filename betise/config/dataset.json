    },
    "collective_anomaly": {
      "enabled": false,
      "mode": "single",
      "location": "middle",
      "num_anomalies": 1
    },
    "contextual_anomaly": {
      "enabled": false,
      "mode": "single",
      "location": "middle",
      "num_anomalies": 1
    }
  }
